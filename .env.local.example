# Copy this file to .env.local and fill in your keys.

# Used by the AI-tutor API route at src/app/api/chat/route.ts.
ANTHROPIC_API_KEY=

# PostgreSQL connection string (Vercel Postgres / Neon / Supabase).
# Locally: Vercel-CLI setter disse automatisk hvis du bruker `vercel env pull`.
POSTGRES_URL=

# HMAC secret for signed session cookies. Generate with:
#   openssl rand -hex 32
# Must be at least 32 characters. Set identically in Vercel env vars.
SESSION_SECRET=
